# ContextOS environment configuration (copy to backend/.env)

# Supermemory Local server (the core memory engine)
SUPERMEMORY_BASE_URL=http://localhost:6767

# Optional: only needed if you enabled auth on your local Supermemory. Leave blank otherwise.
SUPERMEMORY_API_KEY=

# Persistent local user id. Leave blank to auto-generate on first run (stored in backend/.contextos/user_id).
CONTEXTOS_USER_ID=

# ContextOS backend
CONTEXTOS_HOST=127.0.0.1
CONTEXTOS_PORT=8765

# Frontend origin allowed by CORS (Vite dev server)
FRONTEND_URL=http://localhost:5173

# Ambient retrieval tuning
# Minimum Supermemory relevance score (0..1) for a memory to be surfaced proactively.
CONTEXTOS_SURFACE_THRESHOLD=0.42
# chunkThreshold sent to Supermemory search (lower = more candidate results; we filter after).
CONTEXTOS_CHUNK_THRESHOLD=0.0
